# ============================================
# Healthcare Knowledge Navigator - Environment
# ============================================

# --- LLM Configuration ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Embedding Model ---
# Uses local BAAI/bge-large-en-v1.5 by default (no API key needed)
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# --- ChromaDB ---
CHROMA_HOST=chromadb
CHROMA_PORT=8100
CHROMA_COLLECTION=medical_knowledge

# --- Security ---
JWT_SECRET_KEY=your_super_secret_jwt_key_change_this_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Encryption ---
ENCRYPTION_KEY=your_32_byte_encryption_key_here

# --- PubMed ---
NCBI_API_KEY=your_ncbi_api_key_here
NCBI_EMAIL=your_email@example.com

# --- Application ---
APP_NAME=Healthcare Knowledge Navigator
APP_ENV=development
DEBUG=true
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# --- Database ---
DATABASE_URL=sqlite:///./healthcare_navigator.db

# --- Logging ---
LOG_LEVEL=INFO
AUDIT_LOG_FILE=logs/audit.log
