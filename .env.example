# ================================================
#  MedNavigator-AI — Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit the real .env file to version control
# ================================================

# ─── REQUIRED: AI Configuration ─────────────────
# Google Gemini API Key (FREE tier available)
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# ─── Optional: Fallback LLM Providers ───────────
# OpenAI (requires billing)
OPENAI_API_KEY=

# Anthropic Claude (requires billing)
ANTHROPIC_API_KEY=

# ─── Security (CHANGE THESE IN PRODUCTION!) ──────
JWT_SECRET_KEY=change-this-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Fernet encryption key for sensitive database fields
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ─── Optional: PubMed Integration ────────────────
# Get a free key at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=
NCBI_EMAIL=your_email@example.com

# ─── Application Settings ────────────────────────
APP_NAME=Healthcare Knowledge Navigator
APP_ENV=development
DEBUG=true
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ─── Database ────────────────────────────────────
# SQLite for local dev; swap for PostgreSQL in production
DATABASE_URL=sqlite:///./healthcare_navigator.db

# ─── ChromaDB Vector Store ───────────────────────
CHROMA_COLLECTION=medical_knowledge

# ─── Logging ─────────────────────────────────────
LOG_LEVEL=INFO
AUDIT_LOG_FILE=logs/audit.log
